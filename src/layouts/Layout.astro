---
import '../styles/global.css';
import { getEntry } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const { title, description, wide = false } = Astro.props;

const cfgEntry = await getEntry('config', 'site');
const cfg = cfgEntry!.data;

const aboutEntry = await getEntry('pages', 'about');
const hasAbout = !!aboutEntry;

const pageTitle = title ? `${title} · ${cfg.author}` : cfg.author;
const metaDescription = description || cfg.bio;

const navMaxWidth = wide ? 'max-w-5xl' : 'max-w-2xl';
---

<html lang={cfg.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={cfg.author} />
    {cfg.keywords.length > 0 && <meta name="keywords" content={cfg.keywords.join(',')} />}
    {metaDescription && <meta name="description" content={metaDescription} />}
    {cfg.favicon && <link rel="icon" href={cfg.favicon} />}
    {cfg.siteUrl && <link rel="canonical" href={new URL(Astro.url.pathname, cfg.siteUrl).toString()} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..700&family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    {cfg.chineseFont === 'songti' && (
      <link
        href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
      />
    )}
    {cfg.chineseFont === 'wenkai' && (
      <>
        <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
        <link
          href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.6.0/style.css"
          rel="stylesheet"
        />
      </>
    )}

    <title>{pageTitle}</title>
  </head>
  <body data-theme={cfg.theme} data-zh={cfg.chineseFont}>
    <nav
      class:list={[
        'mx-auto flex items-baseline gap-8 px-6 pt-10 pb-2',
        navMaxWidth,
      ]}
    >
      <a href="/" class="label hover:text-ink transition-colors">
        <span class="font-display normal-case text-base tracking-tight text-ink">
          {cfg.author}
        </span>
      </a>
      <a href="/" class="label hover:text-ink transition-colors">home</a>
      {hasAbout && (
        <a href="/about/" class="label hover:text-ink transition-colors">about</a>
      )}
      {cfg.github && (
        <a
          href={cfg.github}
          target="_blank"
          rel="noreferrer"
          class="label ml-auto hover:text-ink transition-colors"
        >
          github ↗
        </a>
      )}
    </nav>

    <style is:global>
      details.wechat > summary::-webkit-details-marker { display: none; }
      details.wechat > summary::marker { content: ""; }
      details.wechat .wechat-popover { display: none; }
      details.wechat[open] .wechat-popover { display: block; }
    </style>

    <slot />

    <footer class:list={['mx-auto mt-32 border-t border-rule px-6 py-12', navMaxWidth]}>
      <div class="flex flex-wrap items-baseline gap-x-8 gap-y-2">
        <span class="font-display text-lg text-ink">{cfg.author}</span>
        <span class="label">© {cfg.since}–{new Date().getFullYear()}</span>
        <span class="ml-auto label">woven by wind·scroll</span>
      </div>
      <div class="mt-4 flex items-center gap-5 text-muted">
        {cfg.email && (
          <a
            href={`mailto:${cfg.email}`}
            aria-label="Email"
            class="hover:text-accent transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
          </a>
        )}
        {cfg.github && (
          <a
            href={cfg.github}
            target="_blank"
            rel="noreferrer"
            aria-label="GitHub"
            class="hover:text-accent transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
          </a>
        )}
        {cfg.wechatQr && (
          <details class="wechat relative">
            <summary
              aria-label="WeChat 公众号"
              class="list-none cursor-pointer hover:text-accent transition-colors"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16.5 10c3.038 0 5.5 2.015 5.5 4.5c0 1.397 -.778 2.645 -2 3.47l0 2.03l-1.964 -1.178a6.6 6.6 0 0 1 -1.536 .178c-3.038 0 -5.5 -2.015 -5.5 -4.5s2.462 -4.5 5.5 -4.5z" />
                <path d="M11.197 15.698c-.69 .196 -1.43 .302 -2.197 .302a8.008 8.008 0 0 1 -2.612 -.432l-2.388 1.432v-2.801c-1.237 -1.082 -2 -2.564 -2 -4.199c0 -3.314 3.134 -6 7 -6c3.482 0 6.373 2.18 6.904 5.039" />
                <path d="M10 8h.01" />
                <path d="M7 8h.01" />
                <path d="M15 14h.01" />
                <path d="M18 14h.01" />
              </svg>
            </summary>
            <div class="wechat-popover absolute bottom-full left-1/2 mb-3 w-max -translate-x-1/2 rounded-md border border-rule bg-surface p-3 shadow-lg">
              <img src={cfg.wechatQr} alt="WeChat 公众号二维码" width="160" height="160" class="block w-40 h-40" />
              <p class="mt-2 text-center label">扫码关注公众号</p>
            </div>
          </details>
        )}
      </div>
    </footer>
  </body>
</html>
