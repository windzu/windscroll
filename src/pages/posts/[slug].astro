---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const { title, summary, date, category, tags, coverUrl, icon, readingMinutes } = post.data;
const iconIsEmoji = icon?.startsWith('emoji:');
const iconValue = iconIsEmoji ? icon!.slice(6) : icon;
---

<Layout title={title} description={summary} wide>
  <main class="mx-auto max-w-5xl px-6">
    <div class="pt-10">
      <a href="/" class="label hover:text-ink transition-colors">← back</a>
    </div>

    <!-- hero grid: main (title+lead) on left, sidebar on right -->
    <div class="mt-14 grid grid-cols-1 gap-14 md:grid-cols-[minmax(0,1fr)_180px] md:gap-20">
      <div class="min-w-0">
        {iconIsEmoji && (
          <div
            class="mb-10 flex h-20 w-20 items-center justify-center rounded-xl border border-hairline bg-surface text-4xl shadow-sm"
          >
            {iconValue}
          </div>
        )}
        {!iconIsEmoji && icon && (
          <img
            src={iconValue}
            alt=""
            class="mb-10 h-20 w-20 rounded-xl border border-hairline object-cover shadow-sm"
          />
        )}

        <h1 class="display text-[clamp(2.4rem,5.5vw,4.5rem)] text-ink">
          {title}
        </h1>

        {summary && (
          <p class="lead mt-8 max-w-xl">
            {summary}
          </p>
        )}
      </div>

      <aside class="space-y-7 md:pt-2">
        {category && (
          <div>
            <div class="label">Category</div>
            <div class="label-value mt-1.5">{category}</div>
          </div>
        )}
        {date && (
          <div>
            <div class="label">Date</div>
            <div class="label-value mt-1.5 font-mono-local">{date}</div>
          </div>
        )}
        <div>
          <div class="label">Reading time</div>
          <div class="label-value mt-1.5">{readingMinutes} min</div>
        </div>
        {tags.length > 0 && (
          <div>
            <div class="label">Tags</div>
            <div class="mt-1.5 flex flex-col gap-0.5 text-sm text-muted font-ui">
              {tags.map((tag) => <span>#{tag}</span>)}
            </div>
          </div>
        )}
        <div>
          <div class="label">Share</div>
          <button
            type="button"
            data-copy-link
            class="label-value mt-1.5 underline decoration-[var(--color-accent-soft)] underline-offset-4 hover:decoration-[var(--color-accent)] cursor-pointer"
          >
            Copy link
          </button>
        </div>
      </aside>
    </div>

    {coverUrl && (
      <div class="mt-20 overflow-hidden rounded-sm">
        <img src={coverUrl} alt="" class="w-full object-cover" style="max-height: 520px;" />
      </div>
    )}

    <div class="mx-auto mt-16 mb-14 max-w-[680px] rule-dot"></div>

    <article class="prose mx-auto max-w-[680px]">
      <Content />
    </article>
  </main>
</Layout>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-copy-link]');
  if (btn) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(location.href);
        const original = btn.textContent;
        btn.textContent = 'Copied ✓';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {
        btn.textContent = 'Copy failed';
      }
    });
  }
</script>
